# ReThread .gitignore - Files to exclude from version control

# Environment variables and secrets
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Flask
instance/
.webassets-cache

# Pytest
.pytest_cache/
.coverage
htmlcov/

# Logs
*.log
logs/

# Database files
*.db
*.sqlite
*.sqlite3

# Temporary files
*.tmp
*.bak
*.temp

# OS specific
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride

# ReThread Environment Configuration Template
# Copy this file to .env and fill in the actual values
# NEVER commit the .env file with real secrets to version control

# ============================================================================
# ANTHROPIC CLAUDE API CONFIGURATION
# ============================================================================

# Get your Anthropic API key from: https://console.anthropic.com/
# It's free to use with generous rate limits
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================

# Flask environment (development or production)
FLASK_ENV=production

# Flask secret key for session management
FLASK_SECRET_KEY=generate-a-random-string-min-24-characters

# Debug mode (False for production, True for development)
FLASK_DEBUG=False

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Host and port for Flask development server
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Application name
APP_NAME=ReThread

# Application version
APP_VERSION=1.0.0

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
